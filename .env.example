# --- Site ---
# Canonieke host van de website. Gebruik in productie altijd de www-variant.
NEXT_PUBLIC_SITE_URL=https://www.pandplicht.nl

# --- Database (P1 — productieopslag) ---
# PostgreSQL-verbindingsstring. Leeg = lokale bestandsadapter (alleen development/demo).
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- E-mail (P1 — transactioneel, bijv. Resend) ---
# Leeg = e-mail uitgeschakeld; leads worden alleen opgeslagen.
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=
LEAD_NOTIFICATION_EMAIL=

# --- Analytics (privacyvriendelijk, cookieloos) ---
# "none" | "plausible" | "umami"
NEXT_PUBLIC_ANALYTICS_PROVIDER=none
NEXT_PUBLIC_ANALYTICS_SITE_ID=

# --- Feature flags ---
# Advertenties staan bij lancering uit. Zet pas aan met werkende labeling en metingen.
ADS_ENABLED=false
# EP-Online-koppeling (energielabels) pas activeren met een toegestane, stabiele interface.
ENABLE_EP_ONLINE_INTEGRATION=false
# Live netcapaciteitsdata pas activeren met een officiële of gelicentieerde interface.
ENABLE_LIVE_GRID_DATA=false

# --- Privacy ---
# Bewaartermijn van assessments in dagen; daarna verwijderen of anonimiseren.
ASSESSMENT_RETENTION_DAYS=30
